---
// @ts-nocheck
---

<footer class="bg-[#020618] px-6 py-16 border-t border-white/5 font-roboto">
    <div
        class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-[1.2fr_1fr_1fr_1fr] gap-12 text-left"
    >
        <div class="flex flex-col gap-4">
            <img
                src="/icons/Luminix.svg"
                alt="Lumimix Logo"
                class="w-32 h-auto"
            />
            <p class="text-[#90A1B9] text-sm leading-relaxed max-w-xs">
                Un festival nocturne immersif où DJs, son et lumière fusionnent
                pour créer un voyage sensoriel unique.
            </p>
        </div>

        <div class="flex flex-col gap-4">
            <h3 class="text-white font-bold tracking-widest text-sm">
                Navigation
            </h3>
            <ul class="flex flex-col gap-2 text-[#90A1B9] text-sm font-medium">
                <li>
                    <a href="/" class="hover:text-white transition-colors"
                        >Accueil</a
                    >
                </li>
                <li>
                    <a
                        href="/programme"
                        class="hover:text-white transition-colors">Programme</a
                    >
                </li>
                <li>
                    <a
                        href="/artistes"
                        class="hover:text-white transition-colors">Artistes</a
                    >
                </li>
                <li>
                    <a href="/scenes" class="hover:text-white transition-colors"
                        >Scènes</a
                    >
                </li>
                <li>
                    <a
                        href="/festival"
                        class="hover:text-white transition-colors"
                        >Le Festival</a
                    >
                </li>
            </ul>
        </div>

        <div class="flex flex-col gap-4">
            <h3 class="text-white font-bold tracking-widest text-sm">
                Informations
            </h3>
            <ul class="flex flex-col gap-2 text-[#90A1B9] text-sm font-medium">
                <li>
                    <a href="/infos" class="hover:text-white transition-colors"
                        >Infos Pratiques</a
                    >
                </li>
                <li>
                    <a
                        href="/contact"
                        class="hover:text-white transition-colors">Contact</a
                    >
                </li>
                <li>
                    <a href="#" class="hover:text-white transition-colors"
                        >CGV</a
                    >
                </li>
                <li>
                    <a href="#" class="hover:text-white transition-colors"
                        >Mentions légales</a
                    >
                </li>
            </ul>
        </div>

        <div class="flex flex-col gap-6">
            <div class="flex flex-col gap-4">
                <h3 class="text-white font-bold tracking-widest text-sm">
                    Suivez-nous
                </h3>
                <div class="flex gap-4">
                    <a href="#" aria-label="YouTube"
                        ><img
                            src="/icons/youtube.svg"
                            alt=""
                            class="w-6 h-6 opacity-70"
                        /></a
                    >
                    <a href="#" aria-label="X"
                        ><img
                            src="/icons/x.svg"
                            alt=""
                            class="w-6 h-6 opacity-70"
                        /></a
                    >
                    <a href="#" aria-label="Instagram"
                        ><img
                            src="/icons/instagram.svg"
                            alt=""
                            class="w-6 h-6 opacity-70"
                        /></a
                    >
                    <a href="#" aria-label="Facebook"
                        ><img
                            src="/icons/facebook.svg"
                            alt=""
                            class="w-6 h-6 opacity-70"
                        /></a
                    >
                </div>
            </div>

            <p class="text-[#90A1B9] text-xs">
                © 2025 Lumimix Festival. Tous droits réservés.
            </p>
        </div>
    </div>
</footer>
