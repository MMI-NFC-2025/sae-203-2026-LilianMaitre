---
import { getImageUrl } from "../../backend/backend.mjs";

const { artiste } = Astro.props;

// Sécurité : on n'affiche rien si l'objet artiste est vide
if (!artiste) return null;

// On prépare les données d'affichage (forcer UTC pour éviter les décalages de jour)
const hasDate = Boolean(artiste.date_presentation);
const d = hasDate ? new Date(artiste.date_presentation) : null;
const dateFormatee = d
    ? d
          .toLocaleDateString("fr-FR", {
              weekday: "long",
              day: "numeric",
              month: "long",
              timeZone: "UTC",
          })
          .replace(/^\w/, (c) => c.toUpperCase())
    : "";

const start = d
    ? `${d.getUTCHours().toString().padStart(2, "0")}:${d
          .getUTCMinutes()
          .toString()
          .padStart(2, "0")}`
    : "--:--";
const end = d
    ? `${((d.getUTCHours() + 2) % 24).toString().padStart(2, "0")}:${d
          .getUTCMinutes()
          .toString()
          .padStart(2, "0")}`
    : "--:--";
const horaire = artiste.horaires || `${start} - ${end}`;
const imageUrl = getImageUrl(artiste, artiste.photo_artiste);
---

<article
    class="relative group bg-[#121826] rounded-[2rem] overflow-hidden border border-white/5 w-full max-w-[340px] transition-all duration-300 hover:scale-[1.02] shadow-2xl"
>
    <a href={`/artistes/${artiste.id}`} class="absolute inset-0 z-50"></a>

    {/* IMAGE avec Badge Genre en haut à droite */}
    <div class="relative w-full h-[320px] overflow-hidden">
        <img
            src={imageUrl}
            alt={artiste.nom_artiste}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        />

        {/* Badge Genre (Techno, House...) */}
        <div
            class="absolute top-4 right-4 bg-[#A855F7] text-white text-[10px] font-bold px-4 py-2 rounded-full uppercase tracking-wider shadow-lg"
        >
            {artiste.genre_artiste}
        </div>
    </div>

    {/* CONTENU TEXTE avec icônes */}
    <div class="p-6 space-y-4">
        <h2 class="text-3xl font-bold text-white tracking-tight leading-none">
            {artiste.nom_artiste}
        </h2>

        <div class="space-y-3">
            {/* Date avec icône calendrier */}
            <div class="flex items-center gap-2 text-[#90A1B9]">
                <img
                    src="/icons/calviolet.svg"
                    alt=""
                    class="w-4 h-4 brightness-0 invert opacity-60"
                />
                <span class="text-sm font-medium">{dateFormatee}</span>
            </div>

            {/* Scène avec icône localisation */}
            <div class="flex items-center gap-2 text-[#90A1B9]">
                <img
                    src="/icons/localisation.svg"
                    alt=""
                    class="w-4 h-4 brightness-0 invert opacity-60"
                />
                <span class="text-sm font-medium"
                    >{artiste.expand?.scene?.nom_scene || "Main Stage"}</span
                >
            </div>

            {/* Horaire simple */}
            <div class="pt-1">
                <p class="text-[#4B5563] text-sm font-bold tracking-wide">
                    {horaire}
                </p>
            </div>
        </div>
    </div>
</article>
