---
// @ts-nocheck
const { nom, image, style, date, scene, horaire } = Astro.props;
---

<article
    class="bg-[#0F172B] rounded-[2rem] overflow-hidden border border-white/5 font-roboto mb-8 w-[339.33px] h-[514.25px] flex flex-col mx-auto"
>
    <div
        class="relative w-[337.85px] h-[337.85px] mx-auto overflow-hidden rounded-t-[2rem]"
    >
        <img src={image} alt={nom} class="w-full h-full object-cover" />

        <span
            class="absolute top-4 right-4 bg-[#A855F7] text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase italic"
        >
            {style}
        </span>
    </div>
    <div class="mt-2">
        <p class="text-[#90A1B9] text-base font-mono tracking-wider opacity-80">
            {horaire}
        </p>
    </div>

    <div class="h-[176px] p-6 flex flex-col">
        <h2
            class="text-[30px] font-bold text-white tracking-tight leading-tight mb-4 truncate"
        >
            {nom}
        </h2>

        <div class="flex flex-col gap-2">
            <div class="flex items-center gap-3">
                <img
                    src="/icons/caldendrier.svg"
                    alt="Calendrier"
                    class="w-5 h-5 shrink-0"
                />
                <span class="text-[#90A1B9] text-sm font-medium">{date}</span>
            </div>

            <div class="flex items-center gap-3">
                <img
                    src="/icons/localisation.svg"
                    alt="Localisation"
                    class="w-5 h-5 shrink-0"
                />
                <span class="text-[#90A1B9] text-sm font-medium">{scene}</span>
            </div>
        </div>

        <div class="mt-4">
            <p
                class="text-[#90A1B9] text-lg font-mono tracking-widest opacity-70"
            >
                {horaire}
            </p>
        </div>
    </div>
</article>

