---
// @ts-nocheck
const { nom, image, style, date, scene, horaire } = Astro.props;
---

<article
    class="bg-[#0F172B] rounded-[2rem] overflow-hidden border border-white/5 font-roboto mb-8 w-[339.33px] h-[514.25px] flex flex-col mx-auto"
>
    <div
        class="relative w-[337.85px] h-[337.85px] mx-auto overflow-hidden rounded-t-[2rem]"
    >
        <img src={image} alt={nom} class="w-full h-full object-cover" />

        <span
            class="absolute top-4 right-4 bg-[#A855F7] text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase italic"
        >
            {style}
        </span>
    </div>

    <div class="px-6 py-5 flex flex-col justify-between flex-grow">
        <h2 class="text-2xl font-bold text-white tracking-tight leading-tight">
            {nom}
        </h2>

        <div class="flex flex-col gap-2 text-[#90A1B9] text-xs font-medium">
            <div class="flex items-center gap-2">
                <img
                    src="/src/assets/icons/caldendrier.svg"
                    alt=""
                    class="w-3.5 h-3.5 opacity-70"
                />
                <span>{date}</span>
            </div>
            <div class="flex items-center gap-2">
                <img
                    src="/src/assets/icons/localisation.svg"
                    alt=""
                    class="w-3.5 h-3.5 opacity-70"
                />
                <span class="text-white">{scene}</span>
            </div>
            <p class="mt-1 opacity-60 font-mono tracking-wider">{horaire}</p>
        </div>
    </div>
</article>
