---
// Code serveur (vide pour éviter les boucles d'import)
---

<header class="fixed top-0 left-0 w-full z-[100] font-roboto bg-[#020618]/90 backdrop-blur-xl border-b border-white/5" style="background-color: rgba(2,6,24,0.9);">
    <div
        class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between relative z-[120]"
    >
        <a href="/" class="transition-transform active:scale-95">
            <img
                src="/icons/Luminix.svg"
                alt="Lumimix Logo"
                class="w-32 h-auto"
            />
        </a>

        <nav
            class="hidden md:flex items-center gap-8 text-sm font-semibold uppercase tracking-[0.18em] text-[#B7C2D9]"
        >
            <a href="/" class="hover:text-white transition">Accueil</a>
            <a href="/programme" class="hover:text-white transition">Programme</a>
            <a href="/artistes" class="hover:text-white transition">Artistes</a>
            <a href="/scenes" class="hover:text-white transition">Scènes</a>
            <a href="/infos" class="hover:text-white transition">Infos</a>
            <a href="/festival" class="hover:text-white transition">Le Festival</a>
            <a
                href="/contact"
                class="text-white bg-gradient-to-r from-[#C27AFF] to-[#FB64B6] px-4 py-2 rounded-full shadow-[0_0_20px_rgba(193,122,255,0.35)]"
            >Contact</a>
        </nav>

        <button
            id="menu-toggle"
            class="text-white p-2 focus:outline-none md:hidden"
            aria-label="Menu"
        >
            <svg
                id="icon-burger"
                xmlns="http://www.w3.org/2000/svg"
                class="h-9 w-9"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16m-7 6h7"></path>
            </svg>
            <svg
                id="icon-close"
                xmlns="http://www.w3.org/2000/svg"
                class="h-9 w-9 hidden"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </div>

    <div
        id="full-menu"
        class="fixed inset-0 bg-[#020618] hidden z-[110] flex-col overflow-y-auto"
    >
        <div
            class="flex items-center justify-between px-6 h-20 border-b border-white/5"
        >
            <a href="/" class="transition-transform active:scale-95">
                <img
                    src="/icons/Luminix.svg"
                    alt="Lumimix Logo"
                    class="w-28 h-auto"
                    loading="lazy"
                />
            </a>
            <button
                id="menu-close"
                class="text-white p-2 focus:outline-none"
                aria-label="Fermer le menu"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-9 w-9"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <nav class="flex-1 flex items-center justify-center px-6 py-10">
            <ul
                class="flex flex-col gap-8 text-center text-3xl font-semibold text-[#B7C2D9]"
            >
                <li>
                    <a href="/" class="hover:text-white transition">Accueil</a>
                </li>
                <li>
                    <a href="/programme" class="hover:text-white transition"
                        >Programme</a
                    >
                </li>
                <li>
                    <a href="/artistes" class="hover:text-white transition"
                        >Artistes</a
                    >
                </li>
                <li>
                    <a href="/scenes" class="hover:text-white transition"
                        >Scènes</a
                    >
                </li>
                <li>
                    <a href="/infos" class="hover:text-white transition"
                        >Infos Pratiques</a
                    >
                </li>
                <li>
                    <a
                        href="/contact"
                        class="bg-gradient-to-r from-[#C27AFF] to-[#FB64B6] bg-clip-text text-transparent font-bold"
                    >
                        Contact
                    </a>
                </li>
                <li>
                    <a href="/festival" class="hover:text-white transition"
                        >Le Festival</a
                    >
                </li>
            </ul>
        </nav>
    </div>
</header>

<script>
    const btn = document.getElementById("menu-toggle");
    const menu = document.getElementById("full-menu");
    const burger = document.getElementById("icon-burger");
    const close = document.getElementById("icon-close");
    const btnClose = document.getElementById("menu-close");

    const openMenu = () => {
        menu?.classList.remove("hidden");
        menu?.classList.add("flex");
        burger?.classList.add("hidden");
        close?.classList.remove("hidden");
        document.body.style.overflow = "hidden";
    };

    const closeMenu = () => {
        menu?.classList.add("hidden");
        menu?.classList.remove("flex");
        burger?.classList.remove("hidden");
        close?.classList.add("hidden");
        document.body.style.overflow = "";
    };

    btn?.addEventListener("click", () => {
        const isHidden = menu?.classList.contains("hidden");
        isHidden ? openMenu() : closeMenu();
    });

    btnClose?.addEventListener("click", closeMenu);
</script>
