---
// @ts-nocheck
---

<header
    class="header bg-[#0B0D17] px-6 py-5 flex justify-between items-center fixed top-0 left-0 right-0 z-[1000]"
>
    <a href="/" class="header__logo block h-10">
        <img
            src="/src/assets/icons/Luminix.svg"
            alt="Luminix"
            class="header__logo-img h-full w-auto block"
        />
    </a>

    <button
        id="menu-toggle"
        class="header__menu-toggle bg-none border-none cursor-pointer flex flex-col gap-[0.375rem] w-10 h-10 justify-center items-center relative md:hidden"
        aria-label="Menu"
    >
        <span
            class="header__menu-toggle-bar block w-full h-[3px] bg-white rounded-sm transition-all duration-300"
        ></span>
        <span
            class="header__menu-toggle-bar block w-full h-[3px] bg-white rounded-sm transition-all duration-300"
        ></span>
        <span
            class="header__menu-toggle-bar block w-full h-[3px] bg-white rounded-sm transition-all duration-300"
        ></span>
    </button>

    <nav
        id="menu-nav"
        class="fixed inset-0 bg-[#0B0D17] translate-x-full transition-transform duration-300 md:static md:translate-x-0 md:bg-transparent z-[999] flex flex-col md:flex-row items-center justify-center h-screen md:h-auto"
    >
        <ul
            class="flex flex-col md:flex-row items-center gap-6 md:gap-8 text-[2.25rem] md:text-sm font-extrabold leading-[1.1] tracking-tight text-white font-roboto text-center"
        >
            <li>
                <a href="/" class="hover:text-purple-400 transition-colors"
                    >Le Festival</a
                >
            </li>
            <li>
                <a
                    href="/programme"
                    class="hover:text-purple-400 transition-colors">Programme</a
                >
            </li>
            <li>
                <a
                    href="/artistes"
                    class="hover:text-purple-400 transition-colors">Artistes</a
                >
            </li>
            <li>
                <a
                    href="/scenes"
                    class="bg-gradient-to-r from-[#C27AFF] to-[#51A2FF] bg-clip-text text-transparent"
                >
                    Scènes
                </a>
            </li>
            <li>
                <a
                    href="/infos"
                    class="hover:text-purple-400 transition-colors text-center"
                    >Infos Pratiques</a
                >
            </li>
            <li>
                <a
                    href="/contact"
                    class="hover:text-purple-400 transition-colors">Contact</a
                >
            </li>
        </ul>
    </nav>
</header>

<style>
    /* Import de la police Roboto comme dans ton index.html */
    @import url("https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap");

    .font-roboto {
        font-family: "Roboto", sans-serif;
    }

    /* Ta logique de croix précise */
    .header__menu-toggle--active {
        gap: 0 !important;
        position: fixed;
        top: 1.25rem;
        right: 1.5rem;
        z-index: 1001;
    }

    .header__menu-toggle--active .header__menu-toggle-bar {
        position: absolute;
        width: 70%;
    }

    .header__menu-toggle--active .header__menu-toggle-bar:nth-child(1) {
        transform: rotate(45deg);
    }

    .header__menu-toggle--active .header__menu-toggle-bar:nth-child(2) {
        opacity: 0;
    }

    .header__menu-toggle--active .header__menu-toggle-bar:nth-child(3) {
        transform: rotate(-45deg);
    }
</style>

<script>
    // @ts-nocheck
    const toggleBtn = document.getElementById("menu-toggle");
    const menuNav = document.getElementById("menu-nav");

    toggleBtn.addEventListener("click", () => {
        toggleBtn.classList.toggle("header__menu-toggle--active");
        menuNav.classList.toggle("translate-x-full");
        document.body.classList.toggle("overflow-hidden");
    });
</script>
