---
// @ts-nocheck
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro"; // Import du composant

const { titre } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{titre} | Lumimix</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,400;0,700;0,900;1,700;1,900&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body
		class="bg-[#020618] text-white font-['Roboto',_sans-serif] flex flex-col min-h-screen"
	>
		<Header />

		<main class="flex-grow">
			<slot />
		</main>

		<Footer />
	</body>
</html>
