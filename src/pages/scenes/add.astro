---
import Layout from "../../layouts/Layout.astro";
---

<Layout titre="Ajouter une Scène | Admin">
    <main class="bg-[#020618] min-h-screen text-white pt-32 pb-20 px-6">
        <div
            class="max-w-3xl mx-auto bg-[#0F172B] border border-white/5 p-8 md:p-12 rounded-[2.5rem] shadow-2xl"
        >
            <h1
                class="text-4xl font-black uppercase tracking-tighter mb-8 text-transparent bg-clip-text bg-gradient-to-r from-[#C27AFF] to-[#FB64B6]"
            >
                Nouvelle Scène
            </h1>

            <div
                id="sceneAuthPanel"
                class="bg-[#121826] border border-white/10 rounded-2xl p-6 flex flex-col gap-4 mb-8"
            >
                <div class="flex items-center justify-between gap-3">
                    <p class="text-white font-bold">Connexion requise</p>
                    <button
                        id="sceneLogout"
                        class="hidden text-xs uppercase font-black tracking-[0.2em] text-[#C27AFF] hover:text-white transition"
                        type="button"
                    >
                        Se déconnecter
                    </button>
                </div>
                <p class="text-[#90A1B9] text-sm">
                    Connecte-toi avec ton compte PocketBase autorisé pour créer
                    des scènes.
                </p>
                <form
                    id="sceneLoginForm"
                    class="grid grid-cols-1 md:grid-cols-2 gap-4"
                >
                    <input
                        id="sceneEmail"
                        type="email"
                        required
                        placeholder="email"
                        class="bg-[#0D1320] border border-white/10 rounded-xl p-3 text-white focus:border-[#C27AFF] outline-none"
                    />
                    <input
                        id="scenePassword"
                        type="password"
                        required
                        placeholder="mot de passe"
                        class="bg-[#0D1320] border border-white/10 rounded-xl p-3 text-white focus:border-[#C27AFF] outline-none"
                    />
                    <button
                        type="submit"
                        class="md:col-span-2 bg-gradient-to-r from-[#C27AFF] to-[#FB64B6] text-white font-black uppercase py-3 rounded-xl hover:opacity-90"
                    >
                        Se connecter
                    </button>
                </form>
                <p id="sceneAuthStatus" class="text-xs text-[#90A1B9]"></p>
            </div>

            <form
                id="sceneForm"
                class="flex flex-col gap-6"
                enctype="multipart/form-data"
            >
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-2">
                        <label
                            class="text-xs font-black uppercase tracking-widest text-[#90A1B9]"
                            >Nom de la scène</label
                        >
                        <input
                            type="text"
                            name="nom_scene"
                            required
                            class="bg-[#121826] border border-white/10 rounded-xl p-4 outline-none focus:border-[#C27AFF]"
                        />
                    </div>
                    <div class="flex flex-col gap-2">
                        <label
                            class="text-xs font-black uppercase tracking-widest text-[#90A1B9]"
                            >Capacité (personnes)</label
                        >
                        <input
                            type="number"
                            name="capacite_scene"
                            required
                            class="bg-[#121826] border border-white/10 rounded-xl p-4 outline-none focus:border-[#C27AFF]"
                        />
                    </div>
                </div>

                <div class="flex flex-col gap-2">
                    <label
                        class="text-xs font-black uppercase tracking-widest text-[#90A1B9]"
                        >Image de la scène</label
                    >
                    <input
                        type="file"
                        name="photo_scene"
                        accept="image/*"
                        required
                        class="bg-[#121826] border border-white/10 rounded-xl p-4 file:bg-[#C27AFF] file:border-0 file:rounded-full file:px-4 file:text-white"
                    />
                </div>

                <div class="flex flex-col gap-2">
                    <label
                        class="text-xs font-black uppercase tracking-widest text-[#90A1B9]"
                        >Description</label
                    >
                    <textarea
                        name="description_scene"
                        rows="5"
                        class="bg-[#121826] border border-white/10 rounded-xl p-4 outline-none focus:border-[#C27AFF] resize-none"
                    ></textarea>
                </div>

                <div
                    class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between"
                >
                    <p id="sceneStatus" class="text-sm text-[#90A1B9]"></p>
                    <button
                        type="submit"
                        class="bg-gradient-to-r from-[#C27AFF] to-[#FB64B6] text-white font-black uppercase py-4 px-6 rounded-xl mt-2 md:mt-0 hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed"
                    >
                        Créer la scène
                    </button>
                </div>
            </form>
        </div>
    </main>
</Layout>

<script is:inline>
    import { pb } from "../../../backend/backend.mjs";

    const form = document.getElementById("sceneForm");
    const authPanel = document.getElementById("sceneAuthPanel");
    const loginForm = document.getElementById("sceneLoginForm");
    const logoutBtn = document.getElementById("sceneLogout");
    const authStatus = document.getElementById("sceneAuthStatus");
    const status = document.getElementById("sceneStatus");
    const submitBtn = form.querySelector("button[type='submit']");

    const updateAuthUI = () => {
        const isAuth = pb.authStore.isValid;
        const email = pb.authStore.model?.email || "";
        form.style.display = isAuth ? "flex" : "none";
        authPanel.classList.toggle("hidden", isAuth);
        logoutBtn.classList.toggle("hidden", !isAuth);
        authStatus.textContent = isAuth
            ? `Connecté${email ? ` en tant que ${email}` : ""}`
            : "Connexion requise pour créer une scène.";
    };

    // Init UI
    updateAuthUI();

    loginForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = document.getElementById("sceneEmail")?.value;
        const password = document.getElementById("scenePassword")?.value;
        authStatus.textContent = "Connexion en cours...";
        loginForm.querySelectorAll("input,button").forEach((el) => {
            el.disabled = true;
        });
        try {
            await pb.collection("users").authWithPassword(email, password);
            authStatus.textContent = "Connecté";
            updateAuthUI();
        } catch (error) {
            authStatus.textContent = "Identifiants incorrects";
            console.error("Auth error (scene)", error);
        } finally {
            loginForm.querySelectorAll("input,button").forEach((el) => {
                el.disabled = false;
            });
        }
    });

    logoutBtn?.addEventListener("click", () => {
        pb.authStore.clear();
        updateAuthUI();
    });

    form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        status.textContent = "Envoi en cours...";
        submitBtn.disabled = true;

        try {
            await pb.collection("scene").create(formData);
            status.textContent = "Scène créée !";
            window.location.href = "/scenes";
        } catch (error) {
            console.error("Erreur PocketBase", error);
            status.textContent = "Erreur : " + (error?.message || "envoi");
            submitBtn.disabled = false;
        }
    });
</script>
