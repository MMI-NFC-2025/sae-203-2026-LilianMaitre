---
// @ts-nocheck
import Layout from "../../layouts/Layout.astro";
import CardArtiste from "../../components/CardArtiste.astro";
import {
    allScenes,
    allArtistesByDate,
    getImageUrl,
} from "../../../backend/backend.mjs";

export const prerender = false;

const { id } = Astro.params;
const scene = (await allScenes()).find((s) => s.id === id);

if (!scene) return Astro.redirect("/404");

const tousLesArtistes = await allArtistesByDate();
const artistesDeLaScene = tousLesArtistes.filter(
    (a) => a.scene === scene.id || a.expand?.scene?.id === scene.id,
);
const heroImage =
    getImageUrl(scene, scene.photo_scene) || "/img/hero_scene.avif";

const getDayKey = (value) => {
    if (!value) return "";
    const raw = value.toString();

    // ISO date (YYYY-MM-DD) -> parse en UTC pour éviter un décalage de jour
    const isoMatch = raw.match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (isoMatch) {
        const [_, y, m, d] = isoMatch;
        const dt = new Date(Date.UTC(Number(y), Number(m) - 1, Number(d)));
        const day = dt.getUTCDay();
        if (day === 5) return "vendredi";
        if (day === 6) return "samedi";
        if (day === 0) return "dimanche";
    }

    const d = new Date(raw);
    if (Number.isNaN(d.getTime())) return raw.toLowerCase();
    const day = d.getUTCDay();
    if (day === 5) return "vendredi";
    if (day === 6) return "samedi";
    if (day === 0) return "dimanche";
    return raw.toLowerCase();
};

const formatJour = (value) => {
    if (!value) return "";
    const d = new Date(value);
    if (Number.isNaN(d.getTime())) return value;
    return d
        .toLocaleDateString("fr-FR", {
            weekday: "long",
            day: "numeric",
            month: "long",
            timeZone: "UTC",
        })
        .replace(/^(\w)/, (c) => c.toUpperCase());
};

const artistesParJour = artistesDeLaScene.reduce((acc, artiste) => {
    const key = getDayKey(artiste.date_presentation) || "autres";
    acc[key] = acc[key] || [];
    acc[key].push(artiste);
    return acc;
}, {});
---

<Layout titre={scene.nom_scene}>
    <main
        class="bg-[#020618] min-h-screen text-white font-['Roboto',_sans-serif] pb-20"
    >
        {/* Lien retour */}
        <a
            href="/scenes"
            class="group absolute top-24 left-6 z-[60]"
            aria-label="Retour à la liste des scènes"
        >
            <h3
                class="text-3xl font-bold text-[#C27AFF] mb-10 tracking-tight flex items-center gap-3"
            >
                <div
                    class="flex items-center justify-center w-8 h-8 rounded-full bg-[#A855F7] text-white group-hover:scale-110 transition-transform shadow-[0_0_15px_rgba(168,85,247,0.5)]"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="3"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </div>

                <span
                    class="text-xs font-black uppercase tracking-[0.2em] text-white"
                >
                    Retour aux scènes
                </span>
            </h3>
        </a>

        {/* HERO */}
        <section class="relative h-[80vh] w-full overflow-hidden">
            <img
                src={heroImage}
                alt={scene.nom_scene}
                class="w-full h-full object-cover shadow-2xl"
            />
            <div
                class="absolute inset-0 bg-gradient-to-t from-[#020618] via-[#020618]/35 to-transparent"
            >
            </div>

            <div
                class="absolute bottom-12 left-6 right-6 max-w-6xl mx-auto z-20 space-y-4"
            >
                <h1 class="titre-scene mb-4">{scene.nom_scene}</h1>

                <div class="flex items-center gap-4 text-lg font-bold">
                    <img src="/icons/localisation.svg" alt="" class="w-6 h-6" />
                    <span class="text-[#C27AFF] tracking-widest">
                        {scene.capacite_scene} personnes
                    </span>
                </div>
            </div>
        </section>

        {/* DESCRIPTION */}
        <section class="px-6 mt-16 max-w-6xl mx-auto">
            <h2 class="titre-section">À propos de la scène</h2>
            <div class="max-w-4xl">
                <p
                    class="text-[#90A1B9] text-xl md:text-2xl leading-relaxed font-medium"
                >
                    {scene.description_scene || "Description à venir..."}
                </p>
            </div>

            {
                scene.caracteristiques ? (
                    <div class="mt-10 space-y-4">
                        <h3 class="text-2xl font-bold text-white tracking-tight">
                            Caractéristiques techniques
                        </h3>
                        <div class="flex flex-wrap gap-3">
                            {scene.caracteristiques
                                .split(",")
                                .filter(Boolean)
                                .map((spec) => (
                                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#1E1B4B] text-[#C27AFF] border border-[#C27AFF]/30 text-sm font-semibold shadow-[0_8px_30px_rgba(131,56,236,0.25)]">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            class="w-4 h-4"
                                        >
                                            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                                        </svg>
                                        {spec.trim()}
                                    </span>
                                ))}
                        </div>
                    </div>
                ) : null
            }
        </section>

        {/* ARTISTES DE LA SCÈNE */}
        <section class="max-w-6xl mx-auto px-6 pb-20 mt-16">
            <h3
                class="text-[#90A1B9] text-3xl font-bold text-white mb-10 tracking-tight flex items-center gap-3"
            >
                Line-up de la scène
            </h3>

            <div class="space-y-12">
                {
                    Object.entries(artistesParJour).map(([jourKey, liste]) => (
                        <div class="space-y-6">
                            <div class="flex items-center gap-3 text-white text-2xl font-extrabold tracking-tight">
                                <img
                                    src="/icons/calviolet.svg"
                                    alt=""
                                    class="w-6 h-6"
                                />
                                <span class="capitalize">
                                    {formatJour(liste[0]?.date_presentation) ||
                                        jourKey}
                                </span>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 justify-items-center">
                                {liste.map((artiste) => (
                                    <CardArtiste artiste={artiste} />
                                ))}
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>
    </main>
</Layout>

<style>
    .titre-scene {
        font-family: "Roboto", sans-serif;
        font-weight: 900;
        font-style: normal;
        text-transform: none;
        line-height: 0.88;
        letter-spacing: -0.05em;
        font-size: clamp(3.2rem, 10vw, 6.5rem);
        display: block;
    }

    .titre-section {
        font-family: "Roboto", sans-serif;
        font-weight: 900;
        font-style: italic;
        text-transform: none;
        color: #a855f7;
        letter-spacing: -0.04em;
        font-size: clamp(2.2rem, 7vw, 4rem);
        margin-bottom: 1.5rem;
    }
</style>
