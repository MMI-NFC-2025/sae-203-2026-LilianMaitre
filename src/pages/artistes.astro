---
// @ts-nocheck
import Layout from "../layouts/Layout.astro";
import CardArtiste from "../components/CardArtiste.astro";
import { allArtistesByDate } from "../../backend/backend.mjs";

// Récupération des données depuis PocketBase
const artistes = await allArtistesByDate();
---

<Layout titre="Artistes | Lumimix Festival">
    <main class="bg-[#020618] min-h-screen">
        {/* --- SECTION HERO (Haut de page) --- */}
        <section
            class="relative h-[60vh] w-full flex flex-col justify-end pb-20 px-6 text-center overflow-hidden"
        >
            <img
                src="/img/artistes.avif"
                alt="Ambiance Festival"
                class="absolute inset-0 w-full h-full object-cover -z-20"
            />
            {/* Dégradé pour la lisibilité du texte */}
            <div
                class="absolute inset-0 bg-gradient-to-t from-[#020618] via-[#020618]/40 to-transparent -z-10"
            >
            </div>

            <div class="relative max-w-4xl mx-auto">
                <h1
                    class="text-6xl md:text-8xl font-black tracking-tighter mb-4 uppercase italic"
                >
                    <span
                        class="bg-gradient-to-r from-[#C27AFF] to-[#FB64B6] bg-clip-text text-transparent"
                    >
                        Artistes
                    </span>
                </h1>
                <p
                    class="text-white text-xl md:text-2xl max-w-xl mx-auto opacity-90 leading-snug font-medium italic"
                >
                    Les plus grands DJs de la scène électronique internationale
                    réunis pour vous.
                </p>
            </div>
        </section>

        {/* --- SECTION GRILLE (Le cœur de la page) --- */}
        <section class="max-w-7xl mx-auto px-6 py-24">
            {
                /* justify-items-center : centre les cartes dans leurs colonnes
                grid-cols-1/2/3 : gère le nombre de cartes selon la taille de l'écran
            */
            }
            <div
                class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-12 justify-items-center"
            >
                {
                    artistes && artistes.length > 0 ? (
                        artistes.map((artiste) => (
                            <CardArtiste artiste={artiste} />
                        ))
                    ) : (
                        <div class="col-span-full text-center py-20">
                            <div class="inline-block p-8 bg-white/5 rounded-[2rem] border border-white/10 backdrop-blur-sm">
                                <p class="text-[#90A1B9] text-xl italic">
                                    Aucun artiste trouvé...
                                </p>
                                <p class="text-xs mt-4 opacity-50 text-white uppercase tracking-widest">
                                    Vérifie la connexion à PocketBase (Port
                                    8090)
                                </p>
                            </div>
                        </div>
                    )
                }
            </div>
        </section>
    </main>
</Layout>

<style>
    h1 {
        font-family: "Roboto", sans-serif;
    }
</style>
