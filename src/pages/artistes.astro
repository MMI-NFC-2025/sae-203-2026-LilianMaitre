---
// @ts-nocheck
import Layout from "../layouts/Layout.astro";
import CardArtiste from "../components/CardArtiste.astro";
import { allArtistesByDate, getImageUrl } from "../../backend/backend.mjs";

// On utilise la fonction de ton backend qui fait le expand de la scène
const artistes = await allArtistesByDate();
---

<Layout titre="Artistes">
    <section
        class="relative min-h-[500px] w-full flex flex-col justify-end pb-16 px-6 text-center overflow-hidden"
    >
        <img
            src="/img/artistes.avif"
            alt=""
            class="absolute inset-0 w-full h-full object-cover -z-20"
        />
        <div
            class="absolute inset-0 bg-gradient-to-t from-[#020618] via-purple-900/40 to-transparent -z-10"
        >
        </div>

        <div class="relative pt-64">
            <h1
                class="text-7xl font-bold tracking-tighter mb-4 font-['Roboto',_sans-serif]"
            >
                <span
                    class="bg-gradient-to-r from-[#C27AFF] to-[#FB64B6] bg-clip-text text-transparent"
                >
                    Artistes
                </span>
            </h1>
            <p
                class="text-white text-lg max-w-md mx-auto opacity-90 leading-snug font-['Roboto',_sans-serif]"
            >
                Les plus grands DJs de la scène électronique internationale
            </p>
        </div>
    </section>

    <section class="px-6 pb-24 max-w-2xl mx-auto flex flex-col gap-12 mt-12">
        {
            artistes.length > 0 ? (
                artistes.map((artiste) => (
                    <CardArtiste
                        nom={artiste.nom_artiste}
                        style={artiste.genre_artiste}
                        scene={
                            artiste.expand?.scene?.nom_scene || "Scène inconnue"
                        }
                        date={artiste.date_presentation}
                        horaire={artiste.horaires}
                        image={getImageUrl(artiste, artiste.photo_artiste)}
                    />
                ))
            ) : (
                <div class="text-center py-20">
                    <p class="text-[#90A1B9] italic">
                        Chargement des artistes...
                    </p>
                    <p class="text-xs mt-2 opacity-50 text-white">
                        Vérifie que PocketBase est lancé sur le port 8090
                    </p>
                </div>
            )
        }
    </section>
</Layout>

