---
import Layout from "../layouts/Layout.astro";
import { allScenes, getImageUrl } from "../../backend/backend.mjs";

const scenes = await allScenes();
---

<Layout titre="Scènes">
    <section
        class="relative min-h-[500px] w-full flex items-center justify-center px-6 text-center overflow-hidden font-roboto mt-16 md:mt-20"
    >
        <img
            src="/img/hero_scene.avif"
            alt=""
            class="absolute inset-0 w-full h-full object-cover -z-20 opacity-80"
        />

        <div
            class="absolute inset-0 bg-gradient-to-t from-[#020618] via-[#020618]/10 to-transparent -z-10"
        >
        </div>

        <div class="relative z-10 py-16">
            <h1
                class="text-7xl md:text-8xl font-bold tracking-tighter mb-6 drop-shadow-[0_5px_15px_rgba(0,0,0,0.5)]"
            >
                <span
                    class="bg-gradient-to-r from-[#C27AFF] to-[#FB64B6] bg-clip-text text-transparent"
                >
                    Scènes
                </span>
            </h1>
            <p
                class="text-white text-xl md:text-2xl max-w-2xl mx-auto font-medium drop-shadow-md px-4"
            >
                Découvrez les univers visuels et sonores de Lumimix
            </p>
        </div>
    </section>

    <section class="px-6 py-20 max-w-2xl mx-auto flex flex-col gap-20">
        {
            scenes.map((scene) => (
                <article class="flex flex-col gap-6 group">
                    <div class="rounded-[2rem] overflow-hidden border border-white/10 shadow-2xl">
                        <img
                            src={getImageUrl(scene, scene.photo_scene)}
                            alt={scene.nom_scene}
                            class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-500"
                        />
                    </div>

                    <div class="flex flex-col gap-6">
                        <h2 class="text-5xl font-bold text-white">
                            {scene.nom_scene}
                        </h2>

                        <p class="text-[#90A1B9] text-lg">
                            {scene.description_scene}
                        </p>

                        <div class="flex items-center gap-2 text-[#90A1B9]">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-6 h-6 text-[#C27AFF]"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                                />
                            </svg>
                            <span class="text-xl font-bold">
                                {scene.capacite_scene} personnes
                            </span>
                        </div>

                        <div class="flex flex-wrap gap-2 mt-2">
                            {scene.caracteristiques
                                ? scene.caracteristiques
                                      .split(",")
                                      .map((spec) => (
                                          <span class="bg-[#1E1B4B] text-[#C27AFF] border border-[#C27AFF]/30 px-4 py-2 rounded-full text-sm font-medium">
                                              {spec.trim()}
                                          </span>
                                      ))
                                : null}
                        </div>

                        <a
                            href={`/scenes/${scene.id}`}
                            class="text-[#C27AFF] font-bold flex items-center gap-2 mt-4 transition-all hover:gap-4"
                        >
                            Voir les artistes <span class="text-2xl">↗</span>
                        </a>
                    </div>
                </article>
            ))
        }
    </section>
    <section class="px-6 py-20 bg-[#020618] font-roboto">
        <div class="max-w-2xl mx-auto">
            <h2 class="text-4xl font-bold text-center mb-16">
                <span
                    class="bg-gradient-to-r from-[#C27AFF] to-[#FB64B6] bg-clip-text text-transparent"
                >
                    Caractéristiques <br /> des Scènes
                </span>
            </h2>

            <div class="flex flex-col gap-8">
                {
                    scenes.map((scene) => (
                        <div class="bg-[#0F172B] border border-white/5 p-10 rounded-[2.5rem] shadow-xl">
                            <h3 class="text-4xl font-bold text-white mb-8">
                                {scene.nom_scene}
                            </h3>

                            <div class="mb-8">
                                <p class="text-[#90A1B9] text-lg mb-1 italic">
                                    Capacité
                                </p>
                                <p class="text-[#C27AFF] text-2xl font-bold">
                                    {scene.capacite_scene} personnes
                                </p>
                            </div>

                            <div>
                                <p class="text-[#90A1B9] text-lg mb-4 italic">
                                    Points forts
                                </p>
                                <ul class="flex flex-col gap-3">
                                    {scene.caracteristiques
                                        ?.split(",")
                                        .map((point) => (
                                            <li class="flex items-center gap-3 text-white text-lg">
                                                <span class="w-2 h-2 bg-[#C27AFF] rounded-full shadow-[0_0_8px_#C27AFF]" />
                                                {point.trim()}
                                            </li>
                                        ))}
                                </ul>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>
</Layout>
