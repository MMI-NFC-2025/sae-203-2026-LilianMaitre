---
// @ts-nocheck
import Layout from "../layouts/Layout.astro";
---

<Layout titre="Lumimix 2025">
	<section
		class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 overflow-hidden py-24"
	>
		<div class="absolute inset-0 -z-10">
			<img
				src="/img/hero_page_principale.avif"
				alt=""
				class="w-full h-full object-cover opacity-40"
			/>
			<div
				class="absolute inset-0 bg-gradient-to-b from-purple-900/20 via-[#020618]/60 to-[#020618]"
			>
			</div>
		</div>

		<div class="max-w-4xl">
			<h1
				class="text-[60px] font-bold uppercase leading-[1.05] tracking-tighter mb-6"
			>
				<span
					class="bg-gradient-to-r from-[#C27AFF] via-[#FB64B6] to-[#51A2FF] bg-clip-text text-transparent"
					>LUMIMIX</span
				><br />
				<span class="text-[#C27AFF]">2025</span>
			</h1>

			<p
				class="text-white text-lg md:text-xl font-normal max-w-xl mx-auto mb-14 leading-relaxed opacity-90"
			>
				Un festival nocturne immersif où DJs, son et lumière fusionnent
				pour créer un voyage sensoriel unique
			</p>

			<div class="flex flex-col gap-6 w-full max-w-sm mx-auto">
				<a
					href="/billetterie"
					class="bg-gradient-to-r from-[#C27AFF] to-[#E60076] py-5 rounded-xl font-bold uppercase tracking-widest text-white shadow-lg shadow-purple-500/20 hover:scale-105 transition-transform"
				>
					Billetterie
				</a>
				<a
					href="/programme"
					class="border border-white/20 bg-white/5 backdrop-blur-md py-5 rounded-xl font-bold uppercase tracking-widest text-white hover:bg-white/10 transition-all"
				>
					Découvrir le programme
				</a>
			</div>
		</div>
	</section>

	<section
		class="grid grid-cols-1 md:grid-cols-3 gap-10 px-6 py-24 max-w-7xl mx-auto"
	>
		<article
			class="flex flex-col items-center justify-center p-12 bg-[#0F172B] rounded-[2.5rem] border border-white/5 shadow-2xl"
		>
			<img
				src="/icons/caldendrier.svg"
				alt=""
				class="w-14 h-14 mb-8"
			/>
			<h2
				class="text-3xl font-bold text-white mb-3 font-roboto uppercase tracking-tight"
			>
				3 Nuits
			</h2>
			<p class="text-[#90A1B9] font-medium italic text-lg">
				18, 19 & 20 Juillet 2025
			</p>
		</article>

		<article
			class="flex flex-col items-center justify-center p-12 bg-[#0F172B] rounded-[2.5rem] border border-white/5 shadow-2xl"
		>
			<img
				src="/icons/localisation.svg"
				alt=""
				class="w-14 h-14 mb-8"
			/>
			<h2
				class="text-3xl font-bold text-white mb-3 font-roboto uppercase tracking-tight text-center"
			>
				Lac de Malsaucy
			</h2>
			<p class="text-[#90A1B9] font-medium italic text-lg">
				Territoire de Belfort (90)
			</p>
		</article>

		<article
			class="flex flex-col items-center justify-center p-12 bg-[#0F172B] rounded-[2.5rem] border border-white/5 shadow-2xl"
		>
			<img
				src="/icons/musique.svg"
				alt=""
				class="w-14 h-14 mb-8"
			/>
			<h2
				class="text-3xl font-bold text-white mb-3 font-roboto uppercase tracking-tight"
			>
				8 Artistes
			</h2>
			<p class="text-[#90A1B9] font-medium italic text-lg">
				Les meilleurs DJs internationaux
			</p>
		</article>
	</section>

	<section
		class="values-section py-24 px-6 max-w-4xl mx-auto flex flex-col items-center gap-16 font-roboto"
	>
		<h2 class="text-[40px] font-bold text-center">
			<span
				class="bg-gradient-to-r from-[#C27AFF] to-[#FB64B6] bg-clip-text text-transparent uppercase tracking-tighter"
				>Nos Valeurs</span
			>
		</h2>

		<ul class="flex flex-col gap-20">
			<li class="flex flex-col items-center text-center">
				<img
					src="/icons/inclusion.svg"
					alt=""
					class="w-20 mb-6"
				/>
				<h3
					class="text-3xl font-bold text-white mb-4 uppercase tracking-tight"
				>
					Inclusion
				</h3>
				<p class="text-[#90A1B9] leading-relaxed text-lg max-w-2xl">
					Un festival ouvert à toutes et tous, où chacun se sent
					accueilli, respecté et libre de vivre la fête, peu importe
					son style ou son origine.
				</p>
			</li>

			<li class="flex flex-col items-center text-center">
				<img
					src="/icons/creativite.svg"
					alt=""
					class="w-20 mb-6"
				/>
				<h3
					class="text-3xl font-bold text-white mb-4 uppercase tracking-tight"
				>
					Créativité
				</h3>
				<p class="text-[#90A1B9] leading-relaxed text-lg max-w-2xl">
					Un terrain d'expression où l'imagination et l'innovation
					prennent vie : des shows qui racontent une histoire, un
					festival unique en renouvellement constant.
				</p>
			</li>

			<li class="flex flex-col items-center text-center">
				<img
					src="/icons/divertissement.svg"
					alt=""
					class="w-20 mb-6"
				/>
				<h3
					class="text-3xl font-bold text-white mb-4 uppercase tracking-tight"
				>
					Divertissement
				</h3>
				<p class="text-[#90A1B9] leading-relaxed text-lg max-w-2xl">
					Un moment de plaisir pur : énergie, danse, émotions
					positives, déconnexion du quotidien — vibrer au son des
					basses et s'en mettre plein les yeux.
				</p>
			</li>
		</ul>
	</section>

	<section
		class="nav-cards grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 px-6 py-24 max-w-7xl mx-auto"
	>
		<a
			href="/programme"
			class="relative aspect-square rounded-[2rem] overflow-hidden group"
		>
			<img
				src="/img/programme.avif"
				alt=""
				class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
			/>
			<div class="absolute inset-0 bg-black/30"></div>
			<h2
				class="absolute bottom-8 left-8 text-3xl font-bold tracking-tighter text-white font-roboto"
			>
				Programme
			</h2>
		</a>

		<a
			href="/artistes"
			class="relative aspect-square rounded-[2rem] overflow-hidden group"
		>
			<img
				src="/img/artistes.avif"
				alt=""
				class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
			/>
			<div class="absolute inset-0 bg-black/30"></div>
			<h2
				class="absolute bottom-8 left-8 text-3xl font-bold tracking-tighter text-white font-roboto"
			>
				Artistes
			</h2>
		</a>

		<a
			href="/scenes"
			class="relative aspect-square rounded-[2rem] overflow-hidden group"
		>
			<img
				src="/img/scenes.avif"
				alt=""
				class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
			/>
			<div class="absolute inset-0 bg-black/30"></div>
			<h2
				class="absolute bottom-8 left-8 text-3xl font-bold tracking-tighter text-white font-roboto"
			>
				Scènes
			</h2>
		</a>

		<a
			href="/infos"
			class="relative aspect-square rounded-[2rem] overflow-hidden group"
		>
			<img
				src="/img/infos.avif"
				alt=""
				class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
			/>
			<div class="absolute inset-0 bg-black/30"></div>
			<h2
				class="absolute bottom-8 left-8 text-3xl font-bold tracking-tighter text-white font-roboto"
			>
				Infos<br />Pratiques
			</h2>
		</a>
	</section>

	<style>
		/* Force la police Roboto Bold 700 (cite: image_10eee4.png) */
		.font-roboto {
			font-family: "Roboto", sans-serif;
			font-weight: 700;
		}
	</style>

	<section
		class="partners-section py-24 px-6 max-w-7xl mx-auto flex flex-col items-center gap-16 font-roboto"
	>
		<h2 class="text-[40px] font-bold text-center">
			<span
				class="bg-gradient-to-r from-[#C27AFF] to-[#FB64B6] bg-clip-text text-transparent uppercase tracking-tighter"
				>Nos Partenaires</span
			>
		</h2>

		<ul class="grid grid-cols-2 lg:grid-cols-3 gap-6 w-full">
			<li
				class="flex flex-col items-center justify-center p-8 bg-[#0F172B] rounded-[1.5rem] border border-white/5 transition-transform hover:scale-105"
			>
				<img
					src="/img/creditmutuel.avif"
					alt="Crédit Mutuel"
					class="h-12 w-auto mb-6"
				/>
				<p
					class="text-[#90A1B9] text-sm font-medium tracking-widest"
				>
					Crédit Mutuel
				</p>
			</li>

			<li
				class="flex flex-col items-center justify-center p-8 bg-[#0F172B] rounded-[1.5rem] border border-white/5 transition-transform hover:scale-105"
			>
				<img
					src="/img/despe.avif"
					alt="Desperados"
					class="h-12 w-auto mb-6"
				/>
				<p
					class="text-[#90A1B9] text-sm font-medium tracking-widest"
				>
					Desperados
				</p>
			</li>

			<li
				class="flex flex-col items-center justify-center p-8 bg-[#0F172B] rounded-[1.5rem] border border-white/5 transition-transform hover:scale-105"
			>
				<img
					src="/img/weezevent.avif"
					alt="Weezevent"
					class="h-12 w-auto mb-6"
				/>
				<p
					class="text-[#90A1B9] text-sm font-medium"
				>
					Weezevent
				</p>
			</li>

			<li
				class="flex flex-col items-center justify-center p-8 bg-[#0F172B] rounded-[1.5rem] border border-white/5 transition-transform hover:scale-105"
			>
				<img
					src="/img/coca.avif"
					alt="Coca cola"
					class="h-12 w-auto mb-6"
				/>
				<p
					class="text-[#90A1B9] text-sm font-mediumtracking-widest"
				>
					Coca cola
				</p>
			</li>

			<li
				class="flex flex-col items-center justify-center p-8 bg-[#0F172B] rounded-[1.5rem] border border-white/5 transition-transform hover:scale-105"
			>
				<img
					src="/img/deezer.avif"
					alt="Deezer"
					class="h-12 w-auto mb-6"
				/>
				<p
					class="text-[#90A1B9] text-sm font-medium tracking-widest"
				>
					Deezer
				</p>
			</li>

			<li
				class="flex flex-col items-center justify-center p-8 bg-[#0F172B] rounded-[1.5rem] border border-white/5 transition-transform hover:scale-105"
			>
				<img
					src="/img/nrj.avif"
					alt="NRJ"
					class="h-12 w-auto mb-6"
				/>
				<p
					class="text-[#90A1B9] text-sm font-medium tracking-widest"
				>
					NRJ
				</p>
			</li>
		</ul>
	</section>
</Layout>


