---
// @ts-nocheck
import Layout from "../../layouts/Layout.astro";
import { allArtistesByDate, getImageUrl } from "../../../backend/backend.mjs";

export const prerender = true;

export async function getStaticPaths() {
    const artistes = await allArtistesByDate();
    return artistes.map((artiste) => ({
        params: { id: artiste.id },
        props: { artiste },
    }));
}

const { id } = Astro.params;
const artistes = await allArtistesByDate();
const artiste = artistes.find((a) => a.id === id);

// --- FONCTION UNIQUE : ON NE LA DÉCLARE QU'UNE FOIS ---
const getPerf = (dateStr) => {
    if (!dateStr) return { date: "Bientôt", horaire: "--:--" };
    const d = new Date(dateStr);

    return {
        date: d
            .toLocaleDateString("fr-FR", {
                weekday: "long",
                day: "numeric",
                month: "long",
            })
            .replace(/^\w/, (c) => c.toUpperCase()),
        horaire: `${d.getHours().toString().padStart(2, "0")}:${d.getMinutes().toString().padStart(2, "0")} - ${((d.getHours() + 2) % 24).toString().padStart(2, "0")}:${d.getMinutes().toString().padStart(2, "0")}`,
    };
};

const stats = artiste
    ? getPerf(artiste.date_presentation)
    : { date: "", horaire: "" };
---

<link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
/>
<script
    src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"
    is:inline></script>

<Layout titre={artiste ? artiste.nom_artiste : "Artiste"}>
    <main
        class="bg-[#020618] min-h-screen text-white font-['Roboto',_sans-serif] pb-20"
    >
        <div class="absolute top-28 left-6 z-[60]">
            <a
                href="/artistes"
                class="group flex items-center gap-3 bg-black/40 backdrop-blur-xl px-5 py-3 rounded-2xl border border-white/10 transition-all duration-300 hover:border-[#A855F7]/50 shadow-2xl"
            >
                <div
                    class="flex items-center justify-center w-8 h-8 rounded-full bg-[#A855F7] text-white group-hover:scale-110 transition-transform shadow-[0_0_15px_rgba(168,85,247,0.5)]"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="3"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </div>

                <span
                    class="text-xs font-black uppercase tracking-[0.2em] text-white"
                >
                    Retour aux artistes
                </span>
            </a>
        </div>
        {
            artiste ? (
                <>
                    {/* HEADER / HERO SECTION */}
                    <section class="relative h-[85vh] w-full overflow-hidden">
                        <img
                            src={getImageUrl(artiste, artiste.photo_artiste)}
                            alt={artiste.nom_artiste}
                            class="w-full h-full object-cover shadow-2xl"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-[#020618] via-[#020618]/30 to-transparent" />

                        <div class="absolute bottom-12 left-6 right-6 max-w-6xl mx-auto z-20">
                            <span class="inline-block bg-[#A855F7] text-white text-[11px] font-black px-4 py-2 rounded-md uppercase tracking-wider mb-6 italic">
                                {artiste.genre_artiste}
                            </span>

                            <h1 class="titre-artiste mb-8">
                                {artiste.nom_artiste}
                            </h1>

                            <div class="flex flex-col gap-6 text-lg font-bold">
                                <div class="flex items-center gap-4">
                                    <img
                                        src="/icons/calviolet.svg"
                                        alt=""
                                        class="w-6 h-6 brightness-0 invert opacity-80"
                                    />
                                    <span class="opacity-90 capitalize">
                                        {stats.date}
                                    </span>
                                    <img
                                        src="/icons/clock.svg"
                                        alt=""
                                        class="w-6 h-6 ml-4 brightness-0 invert opacity-80"
                                    />
                                    <span class="opacity-90">
                                        {stats.horaire}
                                    </span>
                                </div>

                                <div class="flex items-center gap-4">
                                    <img
                                        src="/icons/localisation.svg"
                                        alt=""
                                        class="w-6 h-6"
                                    />
                                    <span class="text-[#C27AFF] uppercase tracking-widest italic">
                                        {artiste.expand?.scene?.nom_scene ||
                                            "Main Stage"}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </section>

                    {/* SECTION BIOGRAPHIE */}
                    <section class="px-6 mt-20 max-w-6xl mx-auto">
                        <h2 class="titre-section">À propos</h2>
                        <div class="max-w-4xl">
                            <p class="text-[#90A1B9] text-xl md:text-2xl leading-relaxed font-medium italic">
                                {artiste.description_artiste ||
                                    "Biographie à venir..."}
                            </p>
                        </div>
                    </section>

                    {/* SECTION GALERIE */}
                    <section class="px-6 mt-24 max-w-6xl mx-auto pb-20">
                        <h2 class="titre-section mb-12">Galerie</h2>
                        <div class="swiper mySwiper relative group rounded-3xl overflow-hidden">
                            <div class="swiper-wrapper">
                                {artiste.galerie_artiste &&
                                artiste.galerie_artiste.length > 0 ? (
                                    artiste.galerie_artiste.map((image) => (
                                        <div class="swiper-slide">
                                            <img
                                                src={getImageUrl(
                                                    artiste,
                                                    image,
                                                )}
                                                alt=""
                                                class="w-full aspect-video object-cover"
                                            />
                                        </div>
                                    ))
                                ) : (
                                    <div class="swiper-slide bg-white/5 h-64 flex items-center justify-center">
                                        <p class="opacity-40 italic">
                                            Aucune image disponible
                                        </p>
                                    </div>
                                )}
                            </div>
                            <div class="swiper-button-next !text-white !bg-[#A855F7]/80 !w-12 !h-12 !rounded-full after:!text-lg after:!font-bold transition-all hover:!bg-[#A855F7]" />
                            <div class="swiper-button-prev !text-white !bg-[#A855F7]/80 !w-12 !h-12 !rounded-full after:!text-lg after:!font-bold transition-all hover:!bg-[#A855F7]" />
                            <div class="swiper-pagination !-bottom-2" />
                        </div>
                    </section>
                </>
            ) : (
                <div class="py-40 text-center font-black uppercase text-4xl italic text-[#C27AFF]">
                    Artiste introuvable.
                </div>
            )
        }
    </main>
    <section class="px-6 mt-12 max-w-6xl mx-auto pb-20">
        <div
            class="bg-[#121826] border border-white/10 rounded-[2rem] p-8 md:p-12 max-w-2xl"
        >
            <h2 class="text-3xl font-bold text-white mb-10 tracking-tight">
                Informations de la performance
            </h2>

            <div class="space-y-8">
                {/* DATE */}
                <div>
                    <p
                        class="text-[#90A1B9] text-sm uppercase tracking-widest mb-2"
                    >
                        Date
                    </p>
                    <p class="text-xl font-medium text-white">{stats.date}</p>
                </div>

                <div>
                    <p
                        class="text-[#90A1B9] text-sm uppercase tracking-widest mb-2"
                    >
                        Horaire
                    </p>
                    <p class="text-xl font-medium text-white">
                        {stats.horaire}
                    </p>
                </div>

                {/* SCÈNE */}
                <div>
                    <p
                        class="text-[#90A1B9] text-sm uppercase tracking-widest mb-2"
                    >
                        Scène
                    </p>
                    <p class="text-xl font-medium text-[#C27AFF]">
                        {artiste.expand?.scene?.nom_scene || "Main Stage"}
                    </p>
                </div>

                {/* GENRE */}
                <div>
                    <p
                        class="text-[#90A1B9] text-sm uppercase tracking-widest mb-2"
                    >
                        Genre
                    </p>
                    <p class="text-xl font-medium text-white">
                        {artiste.genre_artiste}
                    </p>
                </div>
            </div>
        </div>

        <style>
            /* ... Tes styles .titre-artiste, .titre-section et Swiper Pagination que tu as déjà ... */
            /* Assure-toi juste que le line-height du titre-artiste est bien à 0.85 pour l'effet compact */
            .titre-artiste {
                font-family: "Roboto", sans-serif !important;
                font-weight: 900 !important;
                font-style: normal !important;
                text-transform: uppercase !important;
                line-height: 0.85 !important;
                letter-spacing: -0.06em !important;
                font-size: clamp(3.5rem, 15vw, 9rem) !important;
                display: block;
            }

            .titre-section {
                font-family: "Roboto", sans-serif !important;
                font-weight: 900 !important;
                font-style: italic !important;
                text-transform: uppercase !important;
                color: #a855f7 !important;
                letter-spacing: -0.05em !important;
                font-size: clamp(2.5rem, 8vw, 4.5rem) !important;
            }

            /* Style des points du slider */
            :global(.swiper-pagination-bullet) {
                background: #4b1a7a !important;
                opacity: 1 !important;
                width: 10px;
                height: 10px;
                transition: all 0.3s ease;
            }
            :global(.swiper-pagination-bullet-active) {
                background: #fb64b6 !important;
                width: 25px !important;
                border-radius: 5px !important;
            }
        </style>

        <script is:inline>
            document.addEventListener("DOMContentLoaded", () => {
                new Swiper(".mySwiper", {
                    slidesPerView: 1,
                    spaceBetween: 20,
                    centeredSlides: true,
                    loop: true,
                    pagination: {
                        el: ".swiper-pagination",
                        clickable: true,
                    },
                    navigation: {
                        nextEl: ".swiper-button-next",
                        prevEl: ".swiper-button-prev",
                    },
                    breakpoints: {
                        640: { slidesPerView: 1.2 },
                    },
                });
            });
        </script>
    </section></Layout
>
