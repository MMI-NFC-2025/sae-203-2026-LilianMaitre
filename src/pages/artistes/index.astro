---
// @ts-nocheck
import Layout from "../../layouts/Layout.astro";
import CardArtiste from "../../components/CardArtiste.astro"; 
import { allArtistesByDate, getImageUrl } from "../../../backend/backend.mjs";

const artistesBackend = await allArtistesByDate();
---

<Layout titre="Artistes">
    <section class="px-6 py-24 max-w-5xl mx-auto">
        <h1 class="text-5xl font-bold text-white mb-12">Programmation</h1>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
            artistesBackend.map((artiste) => (
                <CardArtiste
                    id={artiste.id} 
                    nom={artiste.nom_artiste}
                    ...
            />
        ))
    }
        </div>
    </section>
</Layout>
