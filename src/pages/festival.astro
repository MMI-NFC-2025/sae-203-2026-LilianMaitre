---
import Layout from "../layouts/Layout.astro";
---

<Layout titre="Le Festival">
    <section
        class="relative h-[65vh] flex flex-col items-center justify-center font-roboto"
    >
        <div class="absolute inset-0 bg-gradient-to-t from-[#020618] z-10">
        </div>

        <img
            src="/img/hero_apropos.avif"
            alt=""
            class="absolute inset-0 w-full h-full object-cover opacity-60 -z-10"
        />

        <h1
            class="relative z-20 text-6xl md:text-8xl font-bold bg-gradient-to-r from-[#C27AFF] to-[#FB64B6] bg-clip-text text-transparent uppercase tracking-tighter"
        >
            Le Festival
        </h1>
    </section>

    <section class="px-6 py-24 max-w-3xl mx-auto font-roboto">
        <h2 class="text-4xl font-bold text-[#C27AFF] mb-12">Notre Histoire</h2>
        <div class="flex flex-col gap-8 text-[#90A1B9] text-lg text-justify">
            <p>Lumimix est né en 2023...</p>
        </div>

        <div class="mt-20 relative group">
            <div
                class="absolute -inset-1 bg-gradient-to-r from-[#C27AFF] to-[#FB64B6] rounded-[2.5rem] blur opacity-20"
            >
            </div>

            <img
                src="/img/illufestival.avif"
                alt=""
                class="relative rounded-[2.5rem] w-full h-[450px] object-cover shadow-2xl border border-white/10"
            />
        </div>
    </section>
</Layout>
